{
  "name": "AssetFlow",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend",
  "workspaceFolder": "/workspaces/AssetFlow",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/AssetFlow,type=bind,consistency=cached",
  "shutdownAction": "stopCompose",
  "forwardPorts": [5432, 8000, 5173],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
